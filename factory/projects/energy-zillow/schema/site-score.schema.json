{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-zillow/site-score.schema.json",
  "title": "SiteRecommendation",
  "type": "object",
  "required": [
    "site_id",
    "address",
    "data_source",
    "data_quality_tier",
    "lat",
    "lon",
    "h3_cell",
    "zip_priority_score",
    "roof_usable_area_m2",
    "estimated_system_kw",
    "roof_complexity_score",
    "solar_access_proxy",
    "profit_score",
    "close_probability",
    "fit_score",
    "effort_score",
    "priority_score",
    "sales_route_score",
    "easy_win_label",
    "lead_temperature",
    "operator_next_step",
    "operator_lane",
    "operator_pitch_angle",
    "why_now_summary",
    "operator_action_summary",
    "roofing_score",
    "solar_score",
    "hvac_score",
    "battery_score",
    "primary_product",
    "secondary_product",
    "primary_product_score",
    "secondary_product_score",
    "primary_product_reason",
    "secondary_product_reason",
    "primary_product_readiness",
    "secondary_product_readiness",
    "primary_product_trigger_gap",
    "secondary_product_trigger_gap",
    "storm_trigger_status",
    "outage_trigger_status",
    "equipment_age_trigger_status",
    "flood_risk_trigger_status",
    "permit_trigger_status",
    "storm_trigger_score",
    "outage_trigger_score",
    "equipment_age_trigger_score",
    "flood_risk_trigger_score",
    "permit_trigger_score",
    "permit_recent_count",
    "permit_recent_types",
    "permit_last_date",
    "permit_last_type",
    "has_storm_trigger_data",
    "has_outage_trigger_data",
    "has_equipment_age_data",
    "has_flood_risk_data",
    "has_permit_trigger_data",
    "trigger_data_gaps",
    "trigger_notes",
    "recommended_pitch",
    "annual_kwh_solar",
    "annual_savings_usd",
    "payback_years",
    "npv_15y_usd",
    "best_option",
    "confidence",
    "confidence_label",
    "requires_site_survey",
    "solar_model",
    "reasons"
  ],
  "properties": {
    "site_id": { "type": "string" },
    "address": { "type": "string" },
    "zip": { "type": ["string", "null"] },
    "city": { "type": ["string", "null"] },
    "state": { "type": ["string", "null"] },
    "data_source": { "type": "string" },
    "source_type": { "type": ["string", "null"] },
    "data_quality_tier": {
      "type": "string",
      "enum": [
        "parcel-grade",
        "osm-footprint-screening",
        "osm-address-screening",
        "synthetic-bootstrap",
        "unknown-screening"
      ]
    },
    "lat": { "type": "number" },
    "lon": { "type": "number" },
    "footprint_area_m2": { "type": ["number", "null"], "minimum": 0 },
    "footprint_perimeter_m": { "type": ["number", "null"], "minimum": 0 },
    "footprint_compactness": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "footprint_vertex_count": { "type": ["integer", "null"], "minimum": 0 },
    "h3_cell": { "type": "string" },
    "zip_priority_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "roof_usable_area_m2": { "type": "number", "minimum": 0 },
    "estimated_system_kw": { "type": "number", "minimum": 0 },
    "roof_complexity_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "solar_access_proxy": { "type": "number", "minimum": 0, "maximum": 1 },
    "profit_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "close_probability": { "type": "number", "minimum": 0, "maximum": 100 },
    "fit_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "effort_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "priority_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "sales_route_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "easy_win_label": {
      "type": "string",
      "enum": ["Easy win", "Medium effort", "Hard sell"]
    },
    "lead_temperature": {
      "type": "string",
      "enum": ["hot", "warm", "skip"]
    },
    "operator_next_step": {
      "type": "string",
      "enum": ["work_now", "follow_up", "deprioritize"]
    },
    "operator_lane": { "type": "string" },
    "operator_pitch_angle": { "type": "string" },
    "why_now_summary": { "type": "string" },
    "operator_action_summary": { "type": "string" },
    "operator_status": {
      "type": ["object", "null"],
      "properties": {
        "status": { "type": "string", "enum": ["unworked", "visited", "contacted", "follow_up", "closed", "skip"] },
        "note": { "type": ["string", "null"] },
        "updated_at": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "roofing_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "solar_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "hvac_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "battery_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "primary_product": { "type": "string" },
    "secondary_product": { "type": "string" },
    "primary_product_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "secondary_product_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "primary_product_reason": { "type": "string" },
    "secondary_product_reason": { "type": "string" },
    "primary_product_readiness": { "type": "string" },
    "secondary_product_readiness": { "type": "string" },
    "primary_product_trigger_gap": { "type": "string" },
    "secondary_product_trigger_gap": { "type": "string" },
    "storm_trigger_status": { "type": "string" },
    "outage_trigger_status": { "type": "string" },
    "equipment_age_trigger_status": { "type": "string" },
    "flood_risk_trigger_status": { "type": "string" },
    "permit_trigger_status": { "type": "string" },
    "storm_trigger_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "outage_trigger_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "equipment_age_trigger_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "flood_risk_trigger_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "permit_trigger_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "permit_recent_count": { "type": ["integer", "string", "null"] },
    "permit_recent_types": { "type": "string" },
    "permit_last_date": { "type": "string" },
    "permit_last_type": { "type": "string" },
    "has_storm_trigger_data": { "type": "boolean" },
    "has_outage_trigger_data": { "type": "boolean" },
    "has_equipment_age_data": { "type": "boolean" },
    "has_flood_risk_data": { "type": "boolean" },
    "has_permit_trigger_data": { "type": "boolean" },
    "trigger_data_gaps": { "type": "string" },
    "trigger_notes": { "type": "string" },
    "recommended_pitch": { "type": "string" },
    "annual_kwh_solar": { "type": "number", "minimum": 0 },
    "annual_kwh_wind": { "type": ["number", "null"], "minimum": 0 },
    "annual_kwh_hybrid": { "type": ["number", "null"], "minimum": 0 },
    "install_cost_solar_usd": { "type": ["number", "null"], "minimum": 0 },
    "install_cost_hybrid_usd": { "type": ["number", "null"], "minimum": 0 },
    "annual_savings_usd": { "type": "number" },
    "payback_years": { "type": "number" },
    "npv_15y_usd": { "type": "number" },
    "best_option": {
      "type": "string",
      "enum": ["solar", "solar+battery", "hybrid", "no-go"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence_label": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "requires_site_survey": { "type": "boolean" },
    "solar_model": { "type": "string" },
    "pvwatts_ratio": { "type": ["number", "null"] },
    "nsrdb_ghi_annual": { "type": ["number", "null"] },
    "nsrdb_dni_annual": { "type": ["number", "null"] },
    "nsrdb_confidence_adjustment": { "type": ["number", "null"] },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
