# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: comma-separated list of allowed chat IDs (leave empty = open to all)
# Get your chat ID by messaging @userinfobot on Telegram
ALLOWED_CHAT_IDS=123456789,987654321

# Optional: voice I/O for Telegram notes
# Preferred provider setup: Gemini
GEMINI_API_KEY=your-gemini-key-here
# Optional explicit provider: gemini | openai | none
VOICE_PROVIDER=gemini

# Optional OpenAI fallback (only needed if using provider=openai)
OPENAI_API_KEY=sk-your-openai-key-here

# Chow runtime model defaults. `gpt-5.3-codex` is the safest OpenAI OAuth default here.
CHOW_PI_PROVIDER=openai-codex
CHOW_PI_MODEL=gpt-5.3-codex
CHOW_PI_FALLBACK_MODELS=google/gemma-4-31b-it,google/gemini-2.5-flash-lite,openai-codex/gpt-5.4-mini,openai-codex/gpt-5.3-codex

# Voice transcription model
# Gemini example: gemini-2.0-flash
# OpenAI example: gpt-4o-mini-transcribe
VOICE_TRANSCRIBE_MODEL=gemini-2.0-flash
# Optional language hint (e.g., en, es)
VOICE_TRANSCRIBE_LANGUAGE=en

# Voice replies (text -> speech)
# Gemini example: gemini-2.5-flash-preview-tts
# OpenAI example: gpt-4o-mini-tts
VOICE_REPLY_MODEL=gemini-2.5-flash-preview-tts
# Gemini example voice: Kore | OpenAI example: alloy
VOICE_REPLY_VOICE=Kore
# opus recommended for Telegram voice-note compatibility
VOICE_REPLY_FORMAT=opus
# default per-chat voice reply state: on/off
VOICE_REPLY_DEFAULT=off

# Optional: Cal.diy booking link used in outreach snippets/context
CAL_DIY_PROVIDER_NAME=cal.diy
CAL_DIY_BOOKING_URL=
